ischart:UpperCretaceous
    a skos:Concept ;
    gts:rank <http://resource.geosciml.org/ontology/timescale/rank/Epoch> ;
    gts:ratifiedGSSP true ;
    rdfs:isDefinedBy <http://resource.geosciml.org/vocabulary/timescale/gts2020> ;
    skos:broader ischart:Cretaceous ;
    skos:definition "A time period from 100.5 to 66.00 million years ago" ;
    skos:inScheme <http://resource.geosciml.org/classifier/ics/ischart> ;
    skos:narrower
        ischart:Campanian ,
        ischart:Cenomanian ,
        ischart:Coniacian ,
        ischart:Maastrichtian ,
        ischart:Santonian ,
        ischart:Turonian ;
    skos:notation "K2"^^ischart:ccgmShortCode ;
    time:hasBeginning
        [
